# Corporate marketing site (this repo)
NEXT_PUBLIC_SITE_URL=https://www.msg-os.com

# ProQPay payroll application (separate repo: proqpay-app)
NEXT_PUBLIC_PROQPAY_APP_URL=https://proqpay.msg-os.com

# Gemini chatbot — use worker keys from ~/.config/ai-apis/env
# Primary + fallback (server-side only, never NEXT_PUBLIC_*)
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_WORKER_1=
GEMINI_WORKER_2=
# Optional additional workers:
# GEMINI_WORKER_3=
# GEMINI_WORKER_IDS=1,2,3
